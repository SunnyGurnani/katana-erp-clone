{
  "name": "forge-erp",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @forge-erp/api db:generate",
    "db:push": "pnpm --filter @forge-erp/api db:push",
    "db:seed": "pnpm --filter @forge-erp/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^7.5.0"
  }
}
