# Database
DATABASE_URL=postgresql://forge:forge_secret@localhost:5432/forgeerp?schema=public

# API secret (JWT signing; min 32 chars — change in production!)
SECRET_KEY=super_secret_jwt_key_change_in_prod

# Optional: webhook HMAC secret (for inbound webhook verification)
# WEBHOOK_SECRET=your_webhook_hmac_secret

# Optional: log level (fatal, error, warn, info, debug, trace, silent)
# LOG_LEVEL=info

# Server
NODE_ENV=development
PORT=4000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000

# QuickBooks Online integration
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:4000/api/v1/accounting/quickbooks/callback
QUICKBOOKS_ENV=sandbox
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting

# Required to encrypt provider tokens at rest
INTEGRATION_ENCRYPTION_KEY=replace_with_a_long_random_secret
