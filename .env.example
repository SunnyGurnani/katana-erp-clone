# Database
DATABASE_URL=postgresql://forge:forge_secret@localhost:5432/forgeerp?schema=public

# Auth — must be >=32 chars (validated by Zod in apps/api/src/env.ts)
SECRET_KEY=change_me_to_a_random_32char_secret

# Token expiry (optional — defaults shown)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Server
NODE_ENV=development
PORT=4000

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000

# MinIO / S3 object storage (optional — file uploads disabled if not configured)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=forgeerp
# MINIO_USE_SSL=false
# MINIO_PUBLIC_URL=http://localhost/files
