# Backend environment template for VM/server deployment (no Docker)
NODE_ENV=production
PORT=4000

# Postgres (managed service or VM-installed Postgres)
DATABASE_URL=postgresql://forge:change_me@127.0.0.1:5432/forgeerp?schema=public

# Auth
SECRET_KEY=replace_with_a_long_random_secret_key_at_least_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000

# S3-compatible object storage (MinIO/S3)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=forgeerp
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=https://api.example.com/files

# Frontend public API URL (used by web app build/start)
NEXT_PUBLIC_API_URL=https://api.example.com
