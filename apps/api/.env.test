# Integration tests: Prisma schema uses postgresql — use a dedicated Postgres database (e.g. createdb forge_erp_test).
# SQLite example (not supported by current schema): DATABASE_URL="file:./test.db"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forge_erp_test
SECRET_KEY=test-secret-key-for-jest-minimum-32-characters-long
ALLOWED_ORIGINS=http://localhost:3000
PORT=4000
NODE_ENV=test
