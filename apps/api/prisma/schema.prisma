  amount      Decimal    @db.Decimal(18, 4)
  taxRateId   String?    @map("tax_rate_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  @@map("sales_order_shipping_fees")
}

model DemandForecast {
