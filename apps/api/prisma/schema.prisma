  status      String                   @default("planned")
  producedAt  DateTime?                @map("produced_at")
  notes       String?
  ingredients MOProductionIngredient[]
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  @@map("mo_productions")
}

model MOProductionIngredient {
  id           String       @id @default(uuid())
  productionId String       @map("production_id")
  production   MOProduction @relation(fields: [productionId], references: [id], onDelete: Cascade)
