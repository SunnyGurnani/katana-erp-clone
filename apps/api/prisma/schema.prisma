generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("roles")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  fullName       String    @map("full_name")
  hashedPassword String    @map("hashed_password")
  isActive       Boolean   @default(true) @map("is_active")
  isSuperuser    Boolean   @default(false) @map("is_superuser")
  roleId         String?   @map("role_id")
  role           Role?     @relation(fields: [roleId], references: [id])
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  moOperations   MOOperationRow[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  @@map("users")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  scopes      String?
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  @@map("api_keys")
}

model Webhook {
  id        String       @id @default(uuid())
  name      String
  url       String
  secret    String?
  isActive  Boolean      @default(true) @map("is_active")
  events    String
  logs      WebhookLog[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  @@map("webhooks")
}

model WebhookLog {
  id             String    @id @default(uuid())
  webhookId      String    @map("webhook_id")
  webhook        Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event          String
  payload        String
  responseStatus Int?      @map("response_status")
  responseBody   String?   @map("response_body")
  attempt        Int       @default(1)
  deliveredAt    DateTime? @map("delivered_at")
  error          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  @@map("webhook_logs")
}

model Location {
  id              String           @id @default(uuid())
  name            String
  address         String?
  isActive        Boolean          @default(true) @map("is_active")
  isDefault       Boolean          @default(false) @map("is_default")
  storageBins     StorageBin[]
  inventoryLevels InventoryLevel[]
  inventoryMovements InventoryMovement[]
  batchStocks     BatchStock[]
  salesOrders            SalesOrder[]
  salesOrderRows         SalesOrderRow[]
  salesOrderFulfillments SalesOrderFulfillment[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  @@map("locations")
}

model StorageBin {
  id              String               @id @default(uuid())
  name            String
  locationId      String               @map("location_id")
  location        Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variantBins     VariantBinLocation[]
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  @@map("storage_bins")
}

model Product {
  id              String    @id @default(uuid())
  name            String
  sku             String?   @unique
  description     String?
  category        String?
  unitOfMeasure   String    @default("pcs") @map("unit_of_measure")
  isActive        Boolean   @default(true) @map("is_active")
  isManufactured  Boolean   @default(false) @map("is_manufactured")
  salesPrice      Decimal?  @map("sales_price") @db.Decimal(18, 4)
  purchasePrice   Decimal?  @map("purchase_price") @db.Decimal(18, 4)
  imageUrl        String?   @map("image_url")
  trackLotsAndExpiry Boolean @default(false) @map("track_lots_and_expiry")
  variants        Variant[]
  boms            BOM[]
  manufacturingOrders ManufacturingOrder[]
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  @@map("products")
}

model Variant {
  id              String           @id @default(uuid())
  productId       String           @map("product_id")
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  name            String
  sku             String?          @unique
  barcode         String?          @unique
  salesPrice      Decimal?         @map("sales_price") @db.Decimal(18, 4)
  purchasePrice   Decimal?         @map("purchase_price") @db.Decimal(18, 4)
  isActive        Boolean          @default(true) @map("is_active")
  inventoryLevels InventoryLevel[]
  inventoryMovements InventoryMovement[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  @@map("variants")
}

model Material {
  id            String   @id @default(uuid())
  name          String
  sku           String?  @unique
  description   String?
  category      String?
  unitOfMeasure String   @default("pcs") @map("unit_of_measure")
  trackLotsAndExpiry Boolean @default(false) @map("track_lots_and_expiry")
  isActive      Boolean  @default(true) @map("is_active")
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(18, 4)
  reorderPoint  Decimal? @map("reorder_point") @db.Decimal(18, 4)
  leadTimeDays  Int?     @map("lead_time_days")
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  @@map("materials")
}

model InventoryLevel {
  id           String   @id @default(uuid())
  variantId    String   @map("variant_id")
  variant      Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locationId   String   @map("location_id")
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  onHand       Decimal  @default(0) @map("on_hand") @db.Decimal(18, 4)
  allocated    Decimal  @default(0) @db.Decimal(18, 4)
  reorderPoint Decimal? @map("reorder_point") @db.Decimal(18, 4)
  reorderQty   Decimal? @map("reorder_qty") @db.Decimal(18, 4)
  safetyStock  Decimal? @map("safety_stock") @db.Decimal(18, 4)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@unique([variantId, locationId])
  @@map("inventory_levels")
}

model InventoryMovement {
  id            String   @id @default(uuid())
  variantId     String   @map("variant_id")
  variant       Variant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  locationId    String   @map("location_id")
  location      Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  qty           Decimal  @db.Decimal(18, 4)
  movementType  String   @map("movement_type")
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id")
  note          String?
  batchId       String?  @map("batch_id")
  batch         Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  purchaseOrderRowId String? @map("purchase_order_row_id")
  purchaseOrderRow   PurchaseOrderRow? @relation(fields: [purchaseOrderRowId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now()) @map("created_at")
  @@map("inventory_movements")
}

model Supplier {
  id             String            @id @default(uuid())
  name           String
  code           String?           @unique
  email          String?
  phone          String?
  address        String?
  currency       String            @default("USD")
  paymentTerms   String?           @map("payment_terms")
  notes          String?
  isActive       Boolean           @default(true) @map("is_active")
  purchaseOrders PurchaseOrder[]
  addresses      SupplierAddress[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  @@map("suppliers")
}

model Customer {
  id           String            @id @default(uuid())
  name         String
  code         String?           @unique
  email        String?
  phone        String?
  address      String?
  currency     String            @default("USD")
  paymentTerms String?           @map("payment_terms")
  notes        String?
  isActive     Boolean           @default(true) @map("is_active")
  salesOrders  SalesOrder[]
  addresses    CustomerAddress[]
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  @@map("customers")
}

model PurchaseOrder {
  id           String                @id @default(uuid())
  number       String                @unique
  supplierId   String?               @map("supplier_id")
  supplier     Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status       String                @default("draft")
  currency     String                @default("USD")
  orderDate    DateTime?             @map("order_date") @db.Date
  expectedDate DateTime?             @map("expected_date") @db.Date
  notes        String?
  locationId   String?               @map("location_id")
  /// Opaque token for supplier portal (confirm / reject / request changes)
  vendorPortalToken   String?        @unique @map("vendor_portal_token")
  vendorInviteSentAt  DateTime?      @map("vendor_invite_sent_at")
  vendorRespondedAt   DateTime?      @map("vendor_responded_at")
  /// Supplier message when rejecting or requesting modifications
  vendorResponseComment String?    @map("vendor_response_comment") @db.Text
  rows                 PurchaseOrderRow[]
  costRows             PurchaseOrderCostRow[]
  outsourcedRecipeRows OutsourcedPORecipeRow[]
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  @@map("purchase_orders")
}

model PurchaseOrderRow {
  id          String        @id @default(uuid())
  orderId     String        @map("order_id")
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  materialId  String?       @map("material_id")
  variantId   String?       @map("variant_id")
  description String?
  qtyOrdered  Decimal       @map("qty_ordered") @db.Decimal(18, 4)
  qtyReceived Decimal       @default(0) @map("qty_received") @db.Decimal(18, 4)
  unitPrice   Decimal?      @map("unit_price") @db.Decimal(18, 4)
  taxRate     Decimal?      @map("tax_rate") @db.Decimal(7, 4)
  inventoryMovements InventoryMovement[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  @@map("purchase_order_rows")
}

model PurchaseOrderCostRow {
  id          String        @id @default(uuid())
  orderId     String        @map("order_id")
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal       @db.Decimal(18, 4)
  createdAt   DateTime      @default(now()) @map("created_at")
  @@map("purchase_order_cost_rows")
}

model SalesOrder {
  id           String                  @id @default(uuid())
  number       String                  @unique
  customerId   String?                 @map("customer_id")
  customer     Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status       String                  @default("draft")
  currency     String                  @default("USD")
  orderDate    DateTime?               @map("order_date") @db.Date
  requiredDate DateTime?               @map("required_date") @db.Date
  notes        String?
  locationId   String?                 @map("location_id")
  location     Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  rows         SalesOrderRow[]
  fulfillments SalesOrderFulfillment[]
  shippingFees SalesOrderShippingFee[]
  addresses    SalesOrderAddress[]
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  @@map("sales_orders")
}

model SalesOrderRow {
  id           String                 @id @default(uuid())
  orderId      String                 @map("order_id")
  order        SalesOrder             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId    String?                @map("variant_id")
  locationId   String?                @map("location_id")
  location     Location?              @relation(fields: [locationId], references: [id], onDelete: SetNull)
  description  String?
  qtyOrdered   Decimal                @map("qty_ordered") @db.Decimal(18, 4)
  qtyPicked    Decimal                @default(0) @map("qty_picked") @db.Decimal(18, 4)
  qtyFulfilled Decimal                @default(0) @map("qty_fulfilled") @db.Decimal(18, 4)
  unitPrice    Decimal?               @map("unit_price") @db.Decimal(18, 4)
  taxRate      Decimal?               @map("tax_rate") @db.Decimal(7, 4)
  fulfillments SalesOrderFulfillment[]
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  @@map("sales_order_rows")
}

model SalesOrderFulfillment {
  id         String     @id @default(uuid())
  orderId    String     @map("order_id")
  order      SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rowId      String     @map("row_id")
  row        SalesOrderRow @relation(fields: [rowId], references: [id], onDelete: Cascade)
  fromPick   Boolean    @default(false) @map("from_pick")
  qty        Decimal    @db.Decimal(18, 4)
  locationId String?    @map("location_id")
  location   Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  isReturn        Boolean    @default(false) @map("is_return")
  notes           String?
  carrier         String?    @map("carrier")
  trackingNumber  String?    @map("tracking_number")
  shipMethod      String?    @map("ship_method")
  batchId         String?    @map("batch_id")
  batch           Batch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now()) @map("created_at")
  @@map("sales_order_fulfillments")
}

model BOM {
  id          String               @id @default(uuid())
  productId   String               @map("product_id")
  product     Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?              @map("variant_id")
  name        String
  qty         Decimal              @default(1) @db.Decimal(18, 4)
  notes       String?
  isActive    Boolean              @default(true) @map("is_active")
  rows        BOMRow[]
  operations  ProductOperation[]
  mos         ManufacturingOrder[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  @@map("boms")
}

model BOMRow {
  id         String   @id @default(uuid())
  bomId      String   @map("bom_id")
  bom        BOM      @relation(fields: [bomId], references: [id], onDelete: Cascade)
  materialId String?  @map("material_id")
  variantId  String?  @map("variant_id")
  qty        Decimal  @db.Decimal(18, 4)
  unitCost   Decimal? @map("unit_cost") @db.Decimal(18, 4)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  @@map("bom_rows")
}

model ProductOperation {
  id              String           @id @default(uuid())
  bomId           String           @map("bom_id")
  bom             BOM              @relation(fields: [bomId], references: [id], onDelete: Cascade)
  name            String
  rank            Int              @default(0)
  durationMinutes Int?             @map("duration_minutes")
  costPerHour     Decimal?         @map("cost_per_hour") @db.Decimal(18, 4)
  notes           String?
  moOperationRows MOOperationRow[]
  createdAt       DateTime         @default(now()) @map("created_at")
  @@map("product_operations")
}

model ManufacturingOrder {
  id            String           @id @default(uuid())
  number        String           @unique
  bomId         String?          @map("bom_id")
  bom           BOM?             @relation(fields: [bomId], references: [id], onDelete: SetNull)
  productId     String           @map("product_id")
  product       Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId     String?          @map("variant_id")
  locationId    String?          @map("location_id")
  status        String           @default("draft")
  qtyPlanned    Decimal          @map("qty_planned") @db.Decimal(18, 4)
  qtyProduced   Decimal          @default(0) @map("qty_produced") @db.Decimal(18, 4)
  plannedStart  DateTime?        @map("planned_start") @db.Date
  plannedEnd    DateTime?        @map("planned_end") @db.Date
  notes         String?
  recipeRows    MORecipeRow[]
  operationRows MOOperationRow[]
  productions   MOProduction[]
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  @@map("manufacturing_orders")
}

model MORecipeRow {
  id          String             @id @default(uuid())
  moId        String             @map("mo_id")
  mo          ManufacturingOrder @relation(fields: [moId], references: [id], onDelete: Cascade)
  materialId  String?            @map("material_id")
  variantId   String?            @map("variant_id")
  qtyPlanned  Decimal            @map("qty_planned") @db.Decimal(18, 4)
  qtyConsumed Decimal            @default(0) @map("qty_consumed") @db.Decimal(18, 4)
  createdAt   DateTime           @default(now()) @map("created_at")
  @@map("mo_recipe_rows")
}

model MOOperationRow {
  id            String              @id @default(uuid())
  moId          String              @map("mo_id")
  mo            ManufacturingOrder  @relation(fields: [moId], references: [id], onDelete: Cascade)
  operationId   String?             @map("operation_id")
  operation     ProductOperation?   @relation(fields: [operationId], references: [id], onDelete: SetNull)
  operatorId    String?             @map("operator_id")
  operator      User?               @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  name          String
  status        String              @default("pending")
  actualMinutes Int?                @map("actual_minutes")
  createdAt     DateTime            @default(now()) @map("created_at")
  @@map("mo_operation_rows")
}

model StockAdjustment {
  id          String   @id @default(uuid())
  variantId   String   @map("variant_id")
  locationId  String   @map("location_id")
  qtyDelta    Decimal  @map("qty_delta") @db.Decimal(18, 4)
  reason      String
  note        String?
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("stock_adjustments")
}

model StockTransfer {
  id             String   @id @default(uuid())
  variantId      String   @map("variant_id")
  fromLocationId String   @map("from_location_id")
  toLocationId   String   @map("to_location_id")
  qty            Decimal  @db.Decimal(18, 4)
  note           String?
  status         String   @default("completed")
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  @@map("stock_transfers")
}

model Stocktake {
  id         String         @id @default(uuid())
  locationId String         @map("location_id")
  status     String         @default("draft")
  notes      String?
  rows       StocktakeRow[]
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  @@map("stocktakes")
}

model StocktakeRow {
  id          String    @id @default(uuid())
  stocktakeId String    @map("stocktake_id")
  stocktake   Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  variantId   String    @map("variant_id")
  countedQty  Decimal   @map("counted_qty") @db.Decimal(18, 4)
  systemQty   Decimal   @map("system_qty") @db.Decimal(18, 4)
  variance    Decimal   @db.Decimal(18, 4)
  createdAt   DateTime  @default(now()) @map("created_at")
  @@map("stocktake_rows")
}

model Batch {
  id           String       @id @default(uuid())
  variantId    String       @map("variant_id")
  batchNumber  String       @map("batch_number")
  expiryDate   DateTime?    @map("expiry_date") @db.Date
  notes        String?
  stocks       BatchStock[]
  fulfillments SalesOrderFulfillment[]
  inventoryMovements InventoryMovement[]
  createdAt    DateTime     @default(now()) @map("created_at")
  @@unique([variantId, batchNumber])
  @@map("batches")
}

model SerialNumber {
  id           String   @id @default(uuid())
  variantId    String   @map("variant_id")
  serialNumber String   @unique @map("serial_number")
  status       String   @default("available")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("serial_numbers")
}

model TaxRate {
  id        String   @id @default(uuid())
  name      String
  rate      Decimal  @db.Decimal(7, 4)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("tax_rates")
}

model SupplierAddress {
  id         String   @id @default(uuid())
  supplierId String   @map("supplier_id")
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type       String   @default("billing")
  line1      String?  @map("line1")
  line2      String?  @map("line2")
  city       String?
  state      String?
  zip        String?
  country    String?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  @@map("supplier_addresses")
}

model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String   @default("billing")
  line1      String?  @map("line1")
  line2      String?  @map("line2")
  city       String?
  state      String?
  zip        String?
  country    String?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  @@map("customer_addresses")
}

model PriceList {
  id        String              @id @default(uuid())
  name      String
  currency  String              @default("USD")
  isDefault Boolean             @default(false) @map("is_default")
  notes     String?
  rows      PriceListRow[]
  customers PriceListCustomer[]
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  @@map("price_lists")
}

model PriceListRow {
  id          String    @id @default(uuid())
  priceListId String    @map("price_list_id")
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  variantId   String?   @map("variant_id")
  serviceId   String?   @map("service_id")
  price       Decimal   @db.Decimal(18, 4)
  minQty      Decimal?  @map("min_qty") @db.Decimal(18, 4)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  @@map("price_list_rows")
}

model PriceListCustomer {
  id          String    @id @default(uuid())
  priceListId String    @map("price_list_id")
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  customerId  String    @map("customer_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  @@map("price_list_customers")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  sku         String?  @unique
  description String?
  price       Decimal? @db.Decimal(18, 4)
  taxRateId   String?  @map("tax_rate_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("services")
}

model SalesReturn {
  id         String           @id @default(uuid())
  number     String           @unique
  orderId    String?          @map("order_id")
  customerId String?          @map("customer_id")
  status     String           @default("draft")
  notes      String?
  rows       SalesReturnRow[]
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  @@map("sales_returns")
}

model SalesReturnRow {
